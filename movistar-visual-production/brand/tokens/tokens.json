{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "brand": "Movistar",
    "version": "1.0.0",
    "source": "brand-visual-guidelines-movistar v2.0.0",
    "confirmed": "2026-06"
  },
  "color": {
    "brand": {
      "blue": { "$value": "#0066FF", "$type": "color", "$description": "Azul Movistar. Color primario. Obligatorio en toda pieza." },
      "white": { "$value": "#FFFAF5", "$type": "color", "$description": "Blanco Movistar. Fondo prioritario. No es blanco puro." },
      "black": { "$value": "#262423", "$type": "color", "$description": "Negro Movistar. Texto y elementos premium." }
    },
    "secondary": {
      "blue-light":   { "$value": "#D3EEFF", "$type": "color" },
      "green-light":  { "$value": "#CEF7BF", "$type": "color" },
      "yellow-light": { "$value": "#FFE99C", "$type": "color" },
      "coral-light":  { "$value": "#FFC5A8", "$type": "color" },
      "blue-dark":    { "$value": "#022D67", "$type": "color" },
      "green-dark":   { "$value": "#38552B", "$type": "color" },
      "yellow-dark":  { "$value": "#5E4A09", "$type": "color" },
      "coral-dark":   { "$value": "#62301A", "$type": "color" }
    },
    "semantic": {
      "accent":         { "$value": "#0066FF", "$type": "color" },
      "accent-hover":   { "$value": "#005EEB", "$type": "color" },
      "text-primary":   { "$value": "#262423", "$type": "color" },
      "text-secondary": { "$value": "#6F7176", "$type": "color" },
      "text-inverse":   { "$value": "#FFFAF5", "$type": "color" },
      "bg-primary":     { "$value": "#FFFAF5", "$type": "color" },
      "bg-secondary":   { "$value": "#F5F5F5", "$type": "color" },
      "success":        { "$value": "#048239", "$type": "color" },
      "success-hover":  { "$value": "#036D30", "$type": "color" },
      "warning":        { "$value": "#926C00", "$type": "color" },
      "warning-hover":  { "$value": "#745600", "$type": "color" },
      "error":          { "$value": "#C10000", "$type": "color" },
      "error-hover":    { "$value": "#AD0000", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "base": { "$value": "\"Movistar Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    }
  },
  "size": {
    "display":     { "$value": "3rem",      "$type": "dimension", "$description": "48px — Hero, headline principal" },
    "h1":          { "$value": "2.25rem",   "$type": "dimension", "$description": "36px — Título de sección" },
    "h2":          { "$value": "1.75rem",   "$type": "dimension", "$description": "28px — Subtítulo principal" },
    "h3":          { "$value": "1.25rem",   "$type": "dimension", "$description": "20px — Subtítulo secundario" },
    "body":        { "$value": "1rem",      "$type": "dimension", "$description": "16px — Texto general" },
    "small":       { "$value": "0.875rem",  "$type": "dimension", "$description": "14px — Caption, metadata" },
    "legal":       { "$value": "0.75rem",   "$type": "dimension", "$description": "12px — Disclaimers" },
    "price":       { "$value": "2rem",      "$type": "dimension", "$description": "32px — Precio destacado" }
  },
  "space": {
    "xs":  { "$value": "4px",  "$type": "dimension" },
    "sm":  { "$value": "8px",  "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "24px", "$type": "dimension" },
    "xl":  { "$value": "40px", "$type": "dimension" },
    "2xl": { "$value": "64px", "$type": "dimension" },
    "3xl": { "$value": "96px", "$type": "dimension" },
    "4xl": { "$value": "128px","$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px",    "$type": "dimension" },
    "xs":   { "$value": "4px",    "$type": "dimension" },
    "sm":   { "$value": "6px",    "$type": "dimension" },
    "md":   { "$value": "8px",    "$type": "dimension", "$description": "Radio canónico Movistar — contenedores conectados" },
    "lg":   { "$value": "12px",   "$type": "dimension" },
    "xl":   { "$value": "16px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "none": { "$value": "none", "$type": "shadow" },
    "xs":   { "$value": "0 1px 2px 0 rgba(38,36,35,0.08)", "$type": "shadow" },
    "sm":   { "$value": "0 2px 4px 0 rgba(38,36,35,0.10)", "$type": "shadow" },
    "md":   { "$value": "0 4px 12px 0 rgba(38,36,35,0.12)", "$type": "shadow" },
    "lg":   { "$value": "0 8px 24px 0 rgba(38,36,35,0.14)", "$type": "shadow" },
    "xl":   { "$value": "0 16px 40px 0 rgba(38,36,35,0.16)", "$type": "shadow" }
  },
  "motion": {
    "duration": {
      "xs":  { "$value": "80ms",  "$type": "duration" },
      "sm":  { "$value": "160ms", "$type": "duration" },
      "md":  { "$value": "240ms", "$type": "duration" },
      "lg":  { "$value": "480ms", "$type": "duration" },
      "xl":  { "$value": "720ms", "$type": "duration" }
    },
    "easing": {
      "out":     { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",   "$type": "cubicBezier" },
      "in-out":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",    "$type": "cubicBezier" },
      "linear":  { "$value": "linear",                           "$type": "cubicBezier" }
    }
  },
  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  },
  "container": {
    "max-width":  { "$value": "1280px", "$type": "dimension" },
    "max-prose":  { "$value": "680px",  "$type": "dimension" }
  }
}
